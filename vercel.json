{
  "buildCommand": "npm run build && npx esbuild api/index.ts --bundle --platform=node --format=esm --outfile=api/index.mjs --external:@neondatabase/serverless",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "dashboard.cavallygroupe.com" }],
      "destination": "/admin",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
