# =============================================================================
# Cavaly Livres — Variables d'environnement (Vercel + Neon)
# Copier ce fichier en `.env` pour le développement local.
# Sur Vercel : Project Settings > Environment Variables.
# =============================================================================

# --- Base de données (Neon Postgres) ---
DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/cavaly?sslmode=require

# --- Authentification (session JWT locale) ---
# Générer une valeur aléatoire forte: `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-strong-random-secret
# Email du compte propriétaire : recevra automatiquement le rôle "admin" à l'inscription
OWNER_EMAIL=admin@cavallygroupe.com

# --- IA (chatbot, analyse de listes scolaires) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# --- Stockage fichiers (AWS S3) ---
S3_BUCKET_NAME=cavally-groupe-uploads
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base publique pour servir les fichiers (bucket public ou CDN/CloudFront)
S3_PUBLIC_URL=https://cavally-groupe-uploads.s3.eu-west-1.amazonaws.com

# --- Cartes (Google Maps) ---
VITE_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Paiement par carte (Stripe) ---
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# --- Mobile Money (UEMOA) ---
WAVE_API_KEY=
WAVE_API_URL=https://api.wave.com
WAVE_BUSINESS_ID=
WAVE_WEBHOOK_SECRET=

MOOV_API_KEY=
MOOV_API_URL=
MOOV_MERCHANT_ID=
MOOV_WEBHOOK_SECRET=

MTN_API_KEY=
MTN_API_URL=
MTN_SUBSCRIPTION_KEY=
MTN_WEBHOOK_SECRET=

ORANGE_API_KEY=
ORANGE_API_URL=
ORANGE_CLIENT_ID=
ORANGE_WEBHOOK_SECRET=

# --- Email (SMTP, confirmations de commande) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- SMS (notifications de commande) ---
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=

# --- URLs publiques ---
APP_URL=https://www.cavallygroupe.com
FRONTEND_URL=https://www.cavallygroupe.com
VITE_FRONTEND_URL=https://www.cavallygroupe.com

# --- Environnement ---
NODE_ENV=production
PORT=3000
